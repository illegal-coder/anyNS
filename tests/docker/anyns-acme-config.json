{
  "admin_addr": ":8080",
  "runtime_addr": ":8081",
  "log_forwarder_addr": ":8082",
  "request_timeout": "3s",
  "plugins": [
    {
      "name": "hns",
      "enabled": true
    }
  ],
  "routes": [
    {
      "name": "hns-default",
      "suffixes": [".hns", ".hsd"],
      "client_views": ["default"],
      "tenants": ["default"],
      "plugin": "hns",
      "priority": 100,
      "fallback": "nxdomain"
    }
  ],
  "powerdns": {
    "authoritative_url": "http://pdns:8081",
    "authoritative_api_key": "side-load-only",
    "server_id": "localhost",
    "request_timeout": "5s"
  },
  "certificates": {
    "enabled": true,
    "directory_url": "https://pebble:14000/dir",
    "account_email": "acme-test@anyns.invalid",
    "accept_tos": true,
    "storage_dir": "/var/lib/anyns/certificates",
    "request_timeout": "60s",
    "dns_propagation_timeout": "20s",
    "dns_poll_interval": "1s",
    "max_attempts": 1,
    "renew_before_days": 30
  },
  "management": {
    "auth_required": false
  }
}
