ANYNS_ADMIN_ADDR=:8080
ANYNS_RUNTIME_ADDR=:8081
ANYNS_LOG_FORWARDER_ADDR=:8082
ANYNS_CONFIG_FILE=/etc/anyns/config.json
ANYNS_REQUEST_TIMEOUT_SECONDS=3
ANYNS_RUNTIME_ENDPOINT=http://anyns-plugin-runtime:8081/api/v1/resolve
ANYNS_RUNTIME_TIMEOUT_SECONDS=3
ANYNS_CLIENT_VIEW=default
ANYNS_TENANT=default
ANYNS_POLICY_TAGS=
ANYNS_HONEYPOT_URL=
ANYNS_HONEYPOT_API_KEY=change-me
ANYNS_HONEYPOT_HMAC_SECRET=change-me
ANYNS_DNSLOG_PATH=/var/lib/anyns/dnslog.jsonl
ANYNS_HONEYPOT_FAILED_QUEUE_PATH=/var/lib/anyns/honeypot-failed.jsonl
ANYNS_HONEYPOT_RETRY_INTERVAL_SECONDS=30
ANYNS_HONEYPOT_MAX_ATTEMPTS=5
ANYNS_ADMIN_PROXY_RUNTIME_CONTROL=true
ANYNS_RUNTIME_CONTROL_URL=http://anyns-plugin-runtime:8081
ANYNS_MANAGEMENT_AUTH_REQUIRED=false
ANYNS_MANAGEMENT_API_KEY=change-me
PDNS_RECURSOR_LOCAL_ADDRESS=0.0.0.0
PDNS_RECURSOR_LOCAL_PORT=53
PDNS_AUTH_API_KEY=change-me
PDNS_AUTH_WEBSERVER_PASSWORD=change-me
ANYNS_PDNS_AUTH_URL=http://pdns-authoritative:8081
ANYNS_PDNS_RECURSOR_URL=http://pdns-recursor:8082
ANYNS_PDNS_SERVER_ID=localhost
ANYNS_CERTIFICATES_ENABLED=false
ANYNS_ACME_DIRECTORY_URL=https://acme-staging-v02.api.letsencrypt.org/directory
ANYNS_ACME_ACCOUNT_EMAIL=
ANYNS_ACME_ACCEPT_TOS=false
ANYNS_CERTIFICATE_STORAGE_DIR=/var/lib/anyns/certificates
ANYNS_ACME_REQUEST_TIMEOUT_SECONDS=300
ANYNS_ACME_DNS_PROPAGATION_TIMEOUT_SECONDS=120
ANYNS_ACME_DNS_POLL_INTERVAL_SECONDS=2
ANYNS_ACME_MAX_ATTEMPTS=3
ANYNS_CERTIFICATE_RENEW_BEFORE_DAYS=30
ICANN_FORWARDERS=1.1.1.1;8.8.8.8
