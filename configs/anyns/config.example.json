  "security": {
    "enabled": true,
    "tunnel_max_qname_length": 180,
    "tunnel_max_label_length": 63,
    "tunnel_entropy_threshold": 4.0,
    "dga_entropy_threshold": 4.2,
    "dga_digit_ratio_threshold": 0.25,
    "query_rate_window_seconds": 60,
    "query_rate_threshold": 120,
    "random_subdomain_window_seconds": 60,
    "random_subdomain_threshold": 50,
    "nxdomain_window_seconds": 60,
    "nxdomain_threshold": 20,
    "block_rebinding": true,
    "abnormal_rr_action": "log_only",
    "reflection_amplification_action": "rate_limit",
    "allowlist_domains": ["trusted.example"],
    "denylist_domains": [".blocked.example"],
    "sinkhole_domains": ["ads.example"],
    "sinkhole_ipv4": "0.0.0.0",
    "sinkhole_ipv6": "::",
    "sinkhole_ttl": 60
  },
  "dnslog": {
    "limit": 1000,
    "path": "/var/lib/anyns/dnslog.jsonl"
  },
  "honeypot": {
    "url": "",
    "api_key": "",
    "api_key_file": "",
    "hmac_secret": "",
    "hmac_secret_file": "",
    "failed_queue_path": "/var/lib/anyns/honeypot-failed.jsonl",
    "failed_queue_max_entries": 10000,
    "retry_interval": "30s",
    "max_attempts": 5,
    "request_timeout": "5s"
  },
  "control_plane": {
    "admin_proxy_runtime": true,
    "runtime_control_url": "http://anyns-plugin-runtime:8081"
  },
  "management": {
    "api_key": "",
    "api_key_file": "",
    "auth_required": false,
    "roles": [
      {
        "id": "ops-reader",
        "scopes": ["plugins:read", "cache:read", "audit:read", "honeypot:read", "management:read"]
      },
      {
        "id": "ops-writer",
        "scopes": ["plugins:write", "cache:write", "policy:write", "honeypot:write", "management:read"]
      }
    ],
    "keys": [
      {
        "id": "ops-read",
        "api_key": "",
        "api_key_file": "",
        "roles": ["ops-reader"],
        "allowed_client_cidrs": ["127.0.0.1/32", "::1/128"]
      },
      {
        "id": "ops-write",
        "api_key": "",
        "api_key_file": "",
        "roles": ["ops-writer"],
        "allowed_client_cidrs": ["127.0.0.1/32", "::1/128"]
      }
    ]
  }
}
