  "routes": [
    {
      "name": "hns-default",
      "domains": ["example.hns", "wallet.hns"],
      "suffixes": [".hns", ".hsd"],
      "client_views": ["default", "adguard"],
      "tenants": ["default"],
      "plugin": "hns",
      "priority": 100,
      "fallback": "icann-recursive"
    },
    {
      "name": "ens-wave1",
      "suffixes": [".eth"],
      "client_views": ["default"],
      "tenants": ["default"],
